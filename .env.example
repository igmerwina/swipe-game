# Copy this file to .env for local development.
# Never commit real secret values.

# Admin route password for creating rooms at /admin.
# If empty, room creation is not password-protected.
CREATE_ROOM_PASSWORD=change-me

# Supabase room store
# Use the project URL only; both formats are accepted, but this is preferred.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ROOMS_TABLE=rooms

# Optional Vercel KV fallback
# KV_URL=
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
# KV_REST_API_READ_ONLY_TOKEN=
